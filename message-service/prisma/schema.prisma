// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  Id                 String   @id @default(uuid())
  FullName           String   @db.VarChar(200)
  AvatarUrl          String?  @db.VarChar(500)
  Bio                String?  @db.VarChar(500)
  ReputationPoints   Int      @default(0) 
  TechStacks         String[] @db.Text
  IsPrivate          Boolean  @default(false)
  ApplicationUserId  String   @db.VarChar(200)

  // ✅ Matching C# naming
  DateCreated        DateTime? @default(now())
  DateModified       DateTime? @updatedAt
  Deleted            Boolean   @default(false)
  DateDeleted        DateTime?
}

model ProfileBlock {
  Id                 String   @id @default(uuid())
  OwnerId            String   @db.VarChar(200)
  BlockedProfileId   String   @db.VarChar(200)

  // ✅ Only dates
  DateCreated        DateTime? @default(now())
  DateModified       DateTime? @updatedAt
}

model UserFollow {
  Id                   String   @id @default(uuid())
  OwnerId              String   @db.VarChar(200)
  FollowingProfileId   String   @db.VarChar(200)

  // ✅ Only dates
  DateCreated          DateTime? @default(now())
  DateModified         DateTime? @updatedAt
}
generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// Core Profile
// ─────────────────────────────────────────────────────────────────────────────

model Profile {
  Id                String    @id
  FullName          String    @db.VarChar(200)
  AvatarUrl         String?   @db.VarChar(500)
  BackgroundUrl     String?   @db.VarChar(500)
  Bio               String?   @db.VarChar(500)
  ReputationPoints  Int       @default(0)
  TechStacks        String[]  @db.Text
  IsPrivate         Boolean   @default(false)
  ApplicationUserId String    @db.VarChar(200)
  DateCreated       DateTime  @default(now())
  DateModified      DateTime  @updatedAt
  Deleted           Boolean   @default(false)
  DateDeleted       DateTime?

  // Relations
  NotificationsReceived Notification[] @relation("NotificationRecipient")
  NotificationsSent     Notification[] @relation("NotificationActor")

  NotificationGlobalSetting NotificationGlobalSetting?
  NotificationMuteSettings  NotificationMuteSetting[]

  @@index([Id])
}

// ─────────────────────────────────────────────────────────────────────────────
// Core Notification
// ─────────────────────────────────────────────────────────────────────────────

model Notification {
  Id              String           @id @default(uuid())

  RecipientId     String           @db.VarChar(200)
  Recipient       Profile          @relation("NotificationRecipient", fields: [RecipientId], references: [Id])

  Type            NotificationType

  ActorId         String?          @db.VarChar(200)
  Actor           Profile?         @relation("NotificationActor", fields: [ActorId], references: [Id])

  EntityType      EntityType?
  EntityId        String?          @db.VarChar(200)

  EntityTitle     String?          @db.Text
  EntityPreview   String?          @db.Text

  Message         String           @db.Text
  ActionUrl       String?          @db.VarChar(500)

  IsRead          Boolean          @default(false)
  ReadAt          DateTime?

  GroupKey        String?          @db.VarChar(200)
  AggregatedCount Int              @default(1)

  DateCreated     DateTime         @default(now())
  DateModified    DateTime         @updatedAt

  @@index([RecipientId, IsRead, DateCreated])
  @@index([GroupKey])
  @@index([ActorId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Global Kill Switch — 1 row per user
// ─────────────────────────────────────────────────────────────────────────────

model NotificationGlobalSetting {
  Id               String   @id @default(uuid())

  ProfileId        String   @unique @db.VarChar(200)
  Profile          Profile  @relation(fields: [ProfileId], references: [Id])

  AllNotifications Boolean  @default(true)

  DateCreated      DateTime @default(now())
  DateModified     DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────────────────────
// Per-Entity Mute
// ─────────────────────────────────────────────────────────────────────────────

model NotificationMuteSetting {
  Id          String           @id @default(uuid())

  ProfileId   String           @db.VarChar(200)
  Profile     Profile          @relation(fields: [ProfileId], references: [Id])

  EntityType  EntityType
  EntityId    String           @db.VarChar(200)

  Type        NotificationType

  DateCreated DateTime         @default(now())

  @@unique([ProfileId, EntityType, EntityId, Type])
  @@index([ProfileId, EntityType, EntityId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

enum NotificationType {
  // Voting
  UPVOTE_POST
  DOWNVOTE_POST
  UPVOTE_ANSWER
  DOWNVOTE_ANSWER
  UPVOTE_COMMENT
  DOWNVOTE_COMMENT

  // Q&A
  NEW_ANSWER
  COMMENT_POST
  COMMENT_ANSWER
  REPLY_COMMENT
  ANSWER_ACCEPTED

  // Follow
  FOLLOW_USER
  FOLLOW_REQUEST
  FOLLOW_ACCEPTED

  // Community
  COMMUNITY_INVITE
  COMMUNITY_JOIN_REQUEST
  COMMUNITY_POST
  COMMUNITY_ROLE_CHANGE
  COMMUNITY_BAN

  // Messaging
  NEW_MESSAGE
  MESSAGE_REQUEST

  // System
  MODERATION_RESULT
  REPUTATION_MILESTONE
  SYSTEM_ANNOUNCEMENT
}

enum EntityType {
  POST
  COMMENT
  ANSWER
  COMMUNITY
  PROFILE
  MESSAGE
}